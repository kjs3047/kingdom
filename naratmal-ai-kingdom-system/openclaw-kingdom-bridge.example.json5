{
  // Example concept for wiring OpenClaw main Telegram binding to the kingdom bridge.
  // Adjust to actual OpenClaw config shape in your deployment.
  agents: {
    list: [
      { id: 'main', default: true },
      { id: 'strategy_planner' },
      { id: 'product_engineering' },
      { id: 'design_studio' },
      { id: 'audit_guard' },
    ],
  },
  bindings: [
    {
      agentId: 'main',
      match: { channel: 'telegram' },
    },
  ],
  notes: {
    bridgeCommand: 'node scripts/telegram-kingdom-bridge.mjs',
    kingdomBaseUrl: 'http://127.0.0.1:43110',
    expectedInput: '{ "message": "...", "sender": "폐하" }',
  },
}
